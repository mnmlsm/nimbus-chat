<Window x:Class="NimbusChat.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard" Height="450" Width="700"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#EAF2F8">
        <StackPanel Margin="30">

            <!-- Titel -->
            <TextBlock Text="Welcome!"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <!-- Weather Block (only text for now) -->
            <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Weather Overview"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="City: Leipzig" Margin="0,10,0,0"/>
                    <TextBlock Text="Temperature: 14°C"/>
                    <TextBlock Text="Condition: Cloudy"/>
                </StackPanel>
            </Border>

            <!-- Buttons -->
            <WrapPanel>

                <Button Content="Profile"
                        Width="120" Height="40"
                        Margin="5"
                        Click="OpenProfile_Click"/>

                <Button Content="Weather"
                        Width="120" Height="40"
                        Margin="5"
                        Click="OpenWeather_Click"/>

                <Button Content="Messages"
                        Width="120" Height="40"
                        Margin="5"
                        Click="OpenMessages_Click"/>

                <Button Content="Settings"
                        Width="120" Height="40"
                        Margin="5"/>

            </WrapPanel>

        </StackPanel>
    </Grid>
</Window>
