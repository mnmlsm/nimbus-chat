<Window x:Class="NimbusChat.WeatherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Weather" Height="400" Width="500"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F4F6F8">
        <StackPanel Margin="30">

            <!-- Titel -->
            <TextBlock Text="Weather Search"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <!-- City Search -->
            <TextBlock Text="Enter city:"/>
            <TextBox x:Name="CityTextBox"
                     Height="30"
                     Margin="0,5,0,15"/>

            <!-- Button -->
            <Button Content="Search"
                    Height="35"
                    Click="Search_Click"/>

            <!-- Result -->
            <Border Background="White"
                    CornerRadius="10"
                    Padding="15"
                    Margin="0,20,0,0">

                <StackPanel>
                    <TextBlock Text="Result:"
                               FontWeight="Bold"/>

                    <TextBlock x:Name="WeatherResult"
                               Margin="0,10,0,0"
                               Text="No data yet"/>
                </StackPanel>

            </Border>

        </StackPanel>
    </Grid>
</Window>