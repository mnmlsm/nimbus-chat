<Window x:Class="NimbusChat.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profile" Height="400" Width="500"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F4F6F8">
        <StackPanel Margin="30">

            <!-- Titel -->
            <TextBlock Text="User Profile"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <!-- Name -->
            <TextBlock Text="Username"/>
            <TextBox x:Name="UsernameBox"
                     Height="30"
                     Margin="0,5,0,15"
                     Text="User123"/>

            <!-- Status -->
            <TextBlock Text="Status"/>
            <TextBox x:Name="StatusBox"
                     Height="30"
                     Margin="0,5,0,15"
                     Text="Feeling good!"/>

            <!-- Favorite City -->
            <TextBlock Text="Favorite City"/>
            <TextBox x:Name="CityBox"
                     Height="30"
                     Margin="0,5,0,20"
                     Text="Leipzig"/>

            <!-- Button -->
            <Button Content="Save"
                    Height="35"
                    Click="Save_Click"/>

        </StackPanel>
    </Grid>
</Window>
